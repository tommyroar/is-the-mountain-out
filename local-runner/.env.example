# local-runner config
#
# Copy to .env and edit. .env is gitignored.

# Image tag to run. Set to a SHA to pin; default is `latest`.
INFERENCE_IMAGE_TAG=latest

# Local port to expose on 127.0.0.1.
INFERENCE_PORT=8080

# Where the inference container is reachable from tick.sh.
INFERENCE_URL=http://127.0.0.1:8080

# Path to the git checkout we'll commit and push to.
# Defaults to the repo root containing this folder.
REPO_PATH=

# Branch to commit + push.
GIT_BRANCH=main

# Identity for the commits. The repo's existing commits use this bot identity.
GIT_AUTHOR_NAME=github-actions[bot]
GIT_AUTHOR_EMAIL=41898282+github-actions[bot]@users.noreply.github.com
