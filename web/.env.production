# Public URL the SPA fetches inference state from. The Worker
# (worker/src/index.ts) writes state.json to the is-the-mountain-out-public
# R2 bucket on each */15 cron tick; this is the bucket's managed r2.dev URL
# with /state.json appended. Replace once the bucket's public domain is
# enabled in the Cloudflare dashboard.
VITE_STATE_URL=https://pub-REPLACE_ME.r2.dev/state.json
